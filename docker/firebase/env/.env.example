# Local defaults only. Do not put secrets or long-lived credentials in this file.
FIREBASE_PROJECT=demo-vocastock
FIREBASE_EMULATOR_SERVICES=auth,firestore,storage,hosting,ui
# Override these host ports in docker/firebase/env/.env only when they collide locally.
FIREBASE_UI_PORT=14000
FIREBASE_HOSTING_PORT=15000
FIREBASE_AUTH_PORT=19099
FIREBASE_FIRESTORE_PORT=18080
FIREBASE_STORAGE_PORT=19199
FIREBASE_HUB_PORT=14400
FIREBASE_LOGGING_PORT=14500
