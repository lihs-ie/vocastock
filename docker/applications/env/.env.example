# API listener ports
# Default values avoid the Firebase Firestore emulator host port (18080).
GRAPHQL_GATEWAY_PORT=18180
COMMAND_API_PORT=18181
QUERY_API_PORT=18182

# Shared API contract
VOCAS_READINESS_PATH=/readyz
RUST_LOG=info

# Worker stable-run contract
VOCAS_WORKER_STABLE_RUN_SECONDS=10
VOCAS_WORKER_POLL_INTERVAL_SECONDS=30

# Firebase project identifier used by seed script and server binaries.
VOCAS_FIREBASE_PROJECT=demo-vocastock

# Adapter host env — required. Production binaries (command-api /
# query-api / workers) panic on boot when any of these is missing,
# because they refuse to fall back to in-memory fixtures. Point the
# hosts at a running Firebase emulator for local / CI, or at the
# production endpoints for real deployments.
PUBSUB_EMULATOR_HOST=
FIRESTORE_EMULATOR_HOST=
STORAGE_EMULATOR_HOST=
FIREBASE_AUTH_EMULATOR_HOST=

# Required: must be `true` in every container that boots the
# production path. `scripts/ci/run_application_container_smoke.sh`
# exports it for you; local docker compose runs expect it here.
VOCAS_PRODUCTION_ADAPTERS=

# Worker external-API credentials. Required at startup for
# explanation-worker / image-worker / billing-worker respectively.
# Placeholder values (e.g. `sk-ant-smoke-placeholder`) are enough to
# clear the startup validation when the PubSub queue is empty (smoke).
# Production deployments must inject the real secrets.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
STABILITY_API_KEY=
STRIPE_SECRET_KEY=

# PubSub topic names for command-api dispatch. Override only when the
# emulator seed script is configured for different topic identifiers.
VOCAS_PUBSUB_TOPIC_EXPLANATION=workflow.explanation-jobs
VOCAS_PUBSUB_TOPIC_IMAGE=workflow.image-jobs
VOCAS_PUBSUB_TOPIC_RETRY=workflow.retry-jobs
VOCAS_PUBSUB_TOPIC_PURCHASE=billing.purchase-jobs

# Optional internal routing defaults
VOCAS_COMMAND_UPSTREAM_BASE_URL=http://command-api:18181
VOCAS_QUERY_UPSTREAM_BASE_URL=http://query-api:18182
