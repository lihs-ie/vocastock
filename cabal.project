-- Workspace-level cabal project. Each Haskell worker also retains a
-- package-local `cabal.project` so builds scoped to a single worker
-- (e.g. Docker multi-stage `cargo`-equivalent) continue to work.
packages:
  packages/haskell/vocas-worker-core
  applications/backend/explanation-worker
  applications/backend/image-worker
-- billing-worker joins the workspace once Phase D creates its cabal file.

with-compiler: ghc-9.2.8
write-ghc-environment-files: never
