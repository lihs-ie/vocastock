                    "meaning": "このプロジェクトは誰が仕切っていますか？"
                  }
                ],
                "collocations": [
                  { "value": "run a business", "meaning": "事業を営む" },
                  { "value": "run a meeting", "meaning": "会議を取り仕切る" }
